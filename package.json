{
  "name": "debate-studio",
  "version": "0.5.0",
  "description": "A local macOS AI debate studio.",
  "author": "Leander",
  "license": "MIT",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "vite build --config vite.lan.config.ts && electron-vite dev",
    "build": "electron-vite build && vite build --config vite.lan.config.ts",
    "icon:mac": "zsh scripts/create-macos-icon.sh",
    "release:mac:arm64": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --arm64",
    "release:community-update": "node scripts/create-community-update.mjs",
    "release:mac:signed": "node scripts/build-macos-signed.mjs",
    "release:notarize": "node scripts/notarize-macos.mjs",
    "release:check": "node scripts/check-release-artifacts.mjs",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cookie": "^11.1.2",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^10.1.0",
    "@fastify/websocket": "^11.3.0",
    "fastify": "^5.10.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "tar": "^7.5.20",
    "uqr": "^0.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "allowScripts": {
    "electron@35.7.5": true,
    "esbuild@0.25.12": true,
    "fsevents@2.3.3": true,
    "electron-winstaller@5.4.0": true
  }
}
